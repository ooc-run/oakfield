PROJECT_NAME           = "Oakfield"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
PROJECT_BRIEF          = "Numerical core APIs"

OUTPUT_DIRECTORY       = "@CMAKE_CURRENT_BINARY_DIR@/docs/api"
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = "@CMAKE_CURRENT_LIST_DIR@"

INPUT                  = "@CMAKE_CURRENT_LIST_DIR@/README.md" \
                         "@CMAKE_CURRENT_LIST_DIR@/core/README.md" \
                         "@CMAKE_CURRENT_LIST_DIR@/integrators/README.md" \
                         "@CMAKE_CURRENT_LIST_DIR@/backends/README.md" \
                         "@CMAKE_CURRENT_LIST_DIR@/include" \
                         "@CMAKE_CURRENT_LIST_DIR@/docs"
EXCLUDE                = "@CMAKE_CURRENT_LIST_DIR@/docs/doxygen-awesome"
USE_MDFILE_AS_MAINPAGE = "@CMAKE_CURRENT_LIST_DIR@/README.md"
FILE_PATTERNS          = *.h *.md *.dox
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */build/* \
                         */build-*/* \
                         */CMakeFiles/* \
                         */docs/doxygen-awesome/* \
                         */internal/* \
                         */*_internal.h \
                         */split_internal.h \
                         */backend_metal_internal.h

EXTRACT_ALL            = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
JAVADOC_AUTOBRIEF      = NO
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = NO

MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_COLORSTYLE        = LIGHT
HTML_EXTRA_STYLESHEET  = "@CMAKE_CURRENT_LIST_DIR@/docs/doxygen-awesome/doxygen-awesome.css" \
                         "@CMAKE_CURRENT_LIST_DIR@/docs/oakfield-doxygen.css"
GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_MAN           = NO

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
EXPAND_ONLY_PREDEF     = NO
SKIP_FUNCTION_MACROS   = YES

QUIET                  = NO
